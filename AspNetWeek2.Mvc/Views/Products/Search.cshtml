@model ProductSearchViewModel

@{
    ViewData["Title"] = "Search Products";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Search Products</h2>
        <p class="page-description">
            Form GET dùng Query String để tìm kiếm sản phẩm theo từ khóa và giá tối thiểu.
        </p>
    </div>

    <a class="btn btn-light"
       asp-controller="Products"
       asp-action="Index">
        Quay lại danh sách
    </a>
</div>

<div class="form-layout">
    <form class="form-box"
          asp-controller="Products"
          asp-action="Search"
          method="get">

        <div class="form-group">
            <label asp-for="Keyword">Từ khóa</label>
            <input asp-for="Keyword"
                   class="form-control"
                   placeholder="Ví dụ: mouse, keyboard, monitor" />
        </div>

        <div class="form-group">
            <label asp-for="MinPrice">Giá tối thiểu</label>
            <input asp-for="MinPrice"
                   class="form-control"
                   placeholder="Ví dụ: 300000" />
        </div>

        <button class="btn" type="submit">
            Search
        </button>

        <a class="btn btn-secondary"
           asp-controller="Products"
           asp-action="Search">
            Reset
        </a>
    </form>

    <div>
        <h3>Search Result</h3>

        <p>
            Keyword: <strong>@Model.Keyword</strong>
        </p>

        <p>
            Min Price: <strong>@Model.MinPrice</strong>
        </p>

        @if (Model.Products.Count == 0)
        {
            <div class="warning-box">
                Không tìm thấy sản phẩm phù hợp. Vui lòng thử từ khóa khác.
            </div>
        }
        else
        {
            <partial name="_ProductSearchResultTable" model="Model.Products" />
        }
    </div>
</div>
