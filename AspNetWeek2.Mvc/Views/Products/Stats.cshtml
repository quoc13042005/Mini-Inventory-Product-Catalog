@model ProductStatsViewModel

@{
    ViewData["Title"] = "Inventory Stats";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Inventory Stats</h2>
        <p class="page-description">
            Trang này giúp bạn xem nhanh tổng quan tình hình tồn kho của cửa hàng.
        </p>
    </div>

    <a class="btn btn-light" href="/Products">
        Quay lại danh sách
    </a>
</div>

<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-number">@Model.TotalProducts</div>
        <div class="stat-label">Tổng số loại sản phẩm</div>
    </div>

    <div class="stat-card">
        <div class="stat-number">@Model.TotalQuantity</div>
        <div class="stat-label">Tổng số lượng tồn kho</div>
    </div>

    <div class="stat-card">
        <div class="stat-number">@Model.TotalInventoryValueText</div>
        <div class="stat-label">Tổng giá trị tồn kho</div>
    </div>

    <div class="stat-card">
        <div class="stat-number text-danger">@Model.OutOfStockCount</div>
        <div class="stat-label">Sản phẩm đã hết hàng</div>
    </div>

    <div class="stat-card">
        <div class="stat-number text-warning">@Model.NeedReorderCount</div>
        <div class="stat-label">Sản phẩm cần nhập thêm</div>
    </div>
</div>

<div class="info-panel">
    <h4>Đánh giá tình hình tồn kho</h4>

    @if (Model.OutOfStockCount > 0)
    {
        <p class="text-danger">
            Có sản phẩm đã hết hàng. Cần kiểm tra và nhập thêm sớm.
        </p>
    }
    else if (Model.NeedReorderCount > 0)
    {
        <p class="text-warning">
            Một số sản phẩm gần hết hàng. Nên lập kế hoạch nhập thêm.
        </p>
    }
    else
    {
        <p class="text-success">
            Tồn kho hiện tại đang ổn định.
        </p>
    }
</div>

<table class="table table-bordered mt-4">
    <tr>
        <th>Tổng số loại sản phẩm</th>
        <td>@Model.TotalProducts</td>
    </tr>

    <tr>
        <th>Tổng số lượng tồn kho</th>
        <td>@Model.TotalQuantity</td>
    </tr>

    <tr>
        <th>Tổng giá trị tồn kho</th>
        <td>@Model.TotalInventoryValueText</td>
    </tr>

    <tr>
        <th>Số sản phẩm đã hết hàng</th>
        <td>@Model.OutOfStockCount</td>
    </tr>

    <tr>
        <th>Số sản phẩm cần nhập thêm</th>
        <td>@Model.NeedReorderCount</td>
    </tr>
</table>
