@model List<AspNetWeek2.Mvc.ViewModels.ProductListItemViewModel>

@{
    ViewData["Title"] = "Products";
}

<div class="page-header">
    <div>
        <h2 class="page-title">Products</h2>
        <p class="page-description">Chỉ hiển thị sản phẩm IsDeleted = false. Nút Delete thực hiện xóa mềm.</p>
    </div>
    <a class="btn" asp-action="Create">Create New</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="success-box">@TempData["Success"]</div>
}

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Name</th>
            <th>Price</th>
            <th>Stock</th>
            <th>Created At</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.Price.ToString("N0")</td>
                <td>@item.StockQuantity</td>
                <td>@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                <td>
                    <a asp-action="Detail" asp-route-id="@item.Id">[Detail]</a>
                    <a asp-action="Edit" asp-route-id="@item.Id">[Edit]</a>
                    <a asp-action="Delete" asp-route-id="@item.Id">[Delete]</a>
                </td>
            </tr>
        }
    </tbody>
</table>
