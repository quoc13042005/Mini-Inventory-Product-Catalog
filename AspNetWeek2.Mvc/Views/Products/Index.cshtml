@model List<ProductListItemViewModel>

@{
    ViewData["Title"] = "Product Catalog";
    var totalItems = Model.Count;
}

<div class="page-header">
    <div>
        <h2 class="page-title">Product Catalog</h2>
        <p class="page-description">
            Đây là trang danh sách sản phẩm của cửa hàng.
            Giao diện được render bằng Partial View.
        </p>
    </div>

    <div>
        <a class="btn btn-secondary"
           asp-controller="Products"
           asp-action="Search">
            Search Product
        </a>

        <a class="btn"
           asp-controller="Products"
           asp-action="Create">
            Create Product
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="success-box">
        @TempData["SuccessMessage"]
    </div>
}

<div class="info-box">
    <strong>Tổng số sản phẩm:</strong> @totalItems
</div>

@if (Model.Count == 0)
{
    <p>Chưa có sản phẩm nào trong hệ thống.</p>
}
else
{
    <div class="product-grid">
        @foreach (var item in Model)
        {
            <partial name="_ProductCard" model="item" />
        }
    </div>
}
