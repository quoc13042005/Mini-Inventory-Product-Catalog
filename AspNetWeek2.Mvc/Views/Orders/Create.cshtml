@model OrderCreateViewModel

@{
    ViewData["Title"] = "Create Order";
}

<h1>Create Order with Transaction</h1>

<div class="row">
    <div class="col-md-6">
        <div class="card p-3">
            <h4 class="mb-3">Order Form</h4>
            <div asp-validation-summary="All" class="text-danger"></div>
            <form asp-action="Create" method="post">
                <div class="form-group mb-3">
                    <label asp-for="CustomerName">Customer Name</label>
                    <input asp-for="CustomerName" class="form-control" />
                </div>
                <div class="form-group mb-3">
                    <label asp-for="ProductId">Product (ID)</label>
                    <input asp-for="ProductId" class="form-control" />
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Quantity">Quantity</label>
                    <input asp-for="Quantity" class="form-control" />
                </div>
                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-controller="Products" asp-action="Index" class="btn btn-secondary">Back</a>
            </form>
        </div>
    </div>
    <div class="col-md-6">
        <div class="alert alert-info">
            <h5 class="alert-heading">Transaction Flow</h5>
            <p>Create Order, add OrderItem, subtract Stock. If any step fails, rollback all changes.</p>
        </div>
    </div>
</div>
