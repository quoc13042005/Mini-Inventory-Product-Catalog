<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AspNetWeek2.Mvc</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <div class="container header-content">
            <div class="brand">
                <a asp-controller="Home" asp-action="Index">AspNet Lab05 MVC</a>
            </div>

            <nav class="main-nav">
                <a asp-controller="Home" asp-action="Index">Dashboard</a>
                <a asp-controller="Products" asp-action="Index">Products</a>
                <a asp-controller="Products" asp-action="Create">Create</a>
                <a asp-controller="Products" asp-action="Trash">Trash</a>
                <a asp-controller="AuditLogs" asp-action="Index">Audit Logs</a>
                <a href="/health/ready">Health</a>
                <a href="/api/products/9999">API Error Demo</a>
            </nav>
        </div>
    </header>

    <main class="container main-content">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container footer-content">
            <span>&copy; 2025 - AspNetWeek2.Mvc - Lab05</span>
            <a href="#">Privacy</a>
        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
